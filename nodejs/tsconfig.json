{
  "compilerOptions": {
    "target": "es2016",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "lib",
    "cli",
    "index.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
